    //  at()
        /* JavaScript me at() method ek modern and useful method hai jo string ya array me se kisi specific index par element nikalne ke kaam aata hai. */

let name = "Harendra";

console.log(name.at(0));   // "H"  (first letter)
console.log(name.at(3));   // "e"
console.log(name.at(-1));  // "a"  (last letter)

